<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Edit Category</title>
  </head>
  <body>
    <h1>Edit Category</h1>
    <form action="/categories/<%= category.id %>/edit" method="POST">
      <input
        name="name"
        type="text"
        value="<%= category.name %>"
      >

      <input
        name="description"
        type="text"
        value="<%= category.description %>"
      >

      <button type="submit">Submit</button>
    </form>
  </body>
</html>
